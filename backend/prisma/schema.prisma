// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}


// Users
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  plan         Plan      @default(FREE)
  proExpiresAt DateTime? @map("pro_expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  settings      UserSettings?
  categories    Category[]
  payables      Payable[]
  reminders     Reminder[]
  notifications Notification[]
  pushTokens    PushToken[]
  incomeSources IncomeSource[]
  savingsGoals  SavingsGoal[]


  @@map("users")
}

// ─── ENUMS ────────────────────────────────────────────
enum Plan {
  FREE
  PRO
}

enum RecurrenceFrequency {
  WEEKLY
  BIWEEKLY
  SEMI_MONTHLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  CUSTOM
}

enum PaymentStatus {
  OUTSTANDING
  PARTIAL
  PAID
  OVERDUE
}

enum NotificationType {
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum Platform {
  IOS
  ANDROID
  WEB
}

// ─── USER SETTINGS ────────────────────────────────────

model UserSettings {
  id                 String              @id @default(uuid())
  userId             String              @unique @map("user_id")
  timezone           String              @default("Asia/Manila")
  currency           String              @default("PHP")
  defaultReminderDays Int                @default(3) @map("default_reminder_days")
  bucketFrequency    RecurrenceFrequency @default(SEMI_MONTHLY) @map("bucket_frequency")
  bucketCycleStart   DateTime            @map("bucket_cycle_start")
  bucketCustomDays   Int?                @map("bucket_custom_days")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_settings")
}

// ─── CATEGORIES ───────────────────────────────────────

model Category {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  name      String
  color     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user     User?     @relation(fields: [userId], references: [id])
  payables Payable[]

  @@unique([name, userId])
  @@map("categories")
}

// ─── PAYABLES ─────────────────────────────────────────

model Payable {
  id                  String               @id @default(uuid())
  userId              String               @map("user_id")
  categoryId          String?              @map("category_id")
  title               String
  provider            String?
  isRecurring         Boolean              @default(false) @map("is_recurring")
  recurrenceFrequency RecurrenceFrequency? @map("recurrence_frequency")
  startDate           DateTime             @map("start_date")
  dueDate             DateTime?            @map("due_date")
  endDate             DateTime?            @map("end_date")
  amountPerPeriod     Decimal              @map("amount_per_period") @db.Decimal(12, 2)
  reminderDaysBefore  Int                  @default(3) @map("reminder_days_before")
  notes               String?
  isArchived          Boolean              @default(false) @map("is_archived")
  deletedAt           DateTime?            @map("deleted_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  user           User             @relation(fields: [userId], references: [id])
  category       Category?        @relation(fields: [categoryId], references: [id])
  paymentPeriods PaymentPeriod[]
  reminders      Reminder[]

  @@map("payables")
}

// ─── PAYMENT PERIODS ──────────────────────────────────

model PaymentPeriod {
  id          String        @id @default(uuid())
  payableId   String        @map("payable_id")
  dueDate     DateTime      @map("due_date")
  amountDue   Decimal       @map("amount_due") @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  paidAt      DateTime?     @map("paid_at")
  fees        Decimal?      @db.Decimal(12, 2)
  status      PaymentStatus @default(OUTSTANDING)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  payable   Payable    @relation(fields: [payableId], references: [id])
  reminders Reminder[]

  @@map("payment_periods")
}

// ─── REMINDERS ────────────────────────────────────────

model Reminder {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  payableId       String             @map("payable_id")
  paymentPeriodId String?            @map("payment_period_id")
  remindAt        DateTime           @map("remind_at")
  type            NotificationType
  status          NotificationStatus @default(PENDING)
  createdAt       DateTime           @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id])
  payable       Payable        @relation(fields: [payableId], references: [id])
  paymentPeriod PaymentPeriod? @relation(fields: [paymentPeriodId], references: [id])

  @@map("reminders")
}

// ─── NOTIFICATIONS ────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─── PUSH TOKENS ──────────────────────────────────────

model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  Platform
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("push_tokens")
}

// ─── INCOME SOURCES (stub) ────────────────────────────

model IncomeSource {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("income_sources")
}

// ─── SAVINGS GOALS (stub) ─────────────────────────────

model SavingsGoal {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  title        String
  targetAmount Decimal  @map("target_amount") @db.Decimal(12, 2)
  savedAmount  Decimal  @default(0) @map("saved_amount") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("savings_goals")
}
